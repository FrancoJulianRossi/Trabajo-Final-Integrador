# Backend environment variables - update secrets before production

PORT=3000
NODE_ENV=development

# Auth
JWT_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRES_IN=7d
SALT_ROUNDS=10

# Database (PostgreSQL)
# adjust credentials/host as needed for your PG server
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=1234
DB_NAME=cinema_DB
DB_PORT=5432

# Frontend (CORS/origin)
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=info

# Seed admin (used by /api/seed)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin
# Mercado Pago Configuration

MERCADOPAGO_ACCESS_TOKEN=APP_USR-5889876705171964-022419-ca38b582d7ec4a076e3e6082eb55f12c-3224235025
MERCADOPAGO_SUCCESS_URL=https://trabajo-final-integrador-frontend.onrender.com/payment-success
MERCADOPAGO_FAILURE_URL=https://trabajo-final-integrador-frontend.onrender.com/payment-failure
MERCADOPAGO_PENDING_URL=https://trabajo-final-integrador-frontend.onrender.com/payment-pending