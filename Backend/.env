# Backend environment variables - update secrets before production

PORT=3000
NODE_ENV=development

# Auth
JWT_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRES_IN=7d
SALT_ROUNDS=10

# Database (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=1234
DB_NAME=cinema_DB
DB_PORT=3306

# Frontend (CORS/origin)
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=info

# Seed admin (used by /api/seed)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin
# Mercado Pago Configuration
MERCADOPAGO_ACCESS_TOKEN=APP_USR-2300563278293573-022309-23fe3667bb29cacdf21b74c573d44a82-3222530500
MERCADOPAGO_SUCCESS_URL=http://localhost:5173/payment-success
MERCADOPAGO_FAILURE_URL=http://localhost:5173/payment-failure
MERCADOPAGO_PENDING_URL=http://localhost:5173/payment-pending